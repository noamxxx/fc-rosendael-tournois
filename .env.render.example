# Copie vers .env.render (non versionné) puis : npm run render:env
# Prérequis : RENDER_API_KEY (Dashboard → Account → API keys)
# Optionnel : RENDER_SERVICE_ID=srv-... sinon --name fc-rosendael-api
# Ne définis pas PORT ici : Render injecte PORT automatiquement.

NODE_ENV=production
ORIGIN=*
ADMIN_PASSWORD=change-moi
ADMIN_TOKEN_SECRET=genere-une-longue-chaine-aleatoire
GOOGLE_CLIENT_ID=
ADMIN_GOOGLE_EMAILS=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
