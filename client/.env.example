# Copie vers .env.production (local, non versionné) ou définis ces variables dans Cloudflare Pages → Settings → Environment variables (section Build).
#
# Cloudflare Pages : mets les MÊMES clés (VITE_*) pour le build, sinon le bouton Google n’apparaît pas.

# Identifiant client OAuth 2 « Application Web » (Google Cloud Console). Même valeur que GOOGLE_CLIENT_ID côté serveur API.
VITE_GOOGLE_CLIENT_ID=

# URL publique de ton API Node (sans slash final), ex. https://api.tondomaine.com
# L’API héberge la logique + la base (Turso ou SQLite) : variables côté serveur → server/.env.example
VITE_API_URL=
