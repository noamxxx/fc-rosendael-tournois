# Copie vers .env (local, non versionné) ou définis les mêmes clés sur ton hébergeur Node (Render, Railway, VPS, etc.).
# Render : préfère le Blueprint `render.yaml` à la racine du repo (variables `sync: false` saisies au 1er déploiement).

# --- Base de données (prod cloud) : Turso ---
# Sur Render (NODE_ENV=production ou RENDER=true) : ces deux variables sont OBLIGATOIRES.
# Le code ignore .turso-local.json et le SQLite fichier en prod pour ne jamais perdre les données au redeploy.
# Crée une base sur https://turso.tech puis :
#   turso db show <nom> --url
#   turso db tokens create <nom>
# Sur le serveur de prod : ne mets pas server/.turso-local.json ; utilise uniquement ces variables.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Base locale (dev / petit déploiement fichier) ---
# Ignoré si TURSO_DATABASE_URL est défini (et pas de .turso-local.json prioritaire).
# DB_PATH=

PORT=5174
ORIGIN=*

# OAuth admin (même client ID que VITE_GOOGLE_CLIENT_ID côté front)
GOOGLE_CLIENT_ID=
ADMIN_GOOGLE_EMAILS=

# À changer en prod
ADMIN_PASSWORD=admin
# Compte limité : page « base Turso » uniquement (pas de gestion des tournois). Défaut code 1256 si absent.
ADMIN_TURSO_PASSWORD=1256
ADMIN_TOKEN_SECRET=rosendael-dev-secret
